            <span class="ledger-count">N1–N3</span>
            <span class="pass-pill">Pass</span>
          </div>
          <div class="ledger-row">
            <span class="ledger-suite">Kernel</span>
            <span class="ledger-levels">K1 eval &middot; K2 policy-aware &middot; K3 orchestrated</span>
            <span class="ledger-count">K1</span>
            <span class="pass-pill">Pass</span>
          </div>
          <div class="ledger-row">
            <span class="ledger-suite">Settlers</span>
