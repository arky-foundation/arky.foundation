    <section class="band section" id="standard" aria-labelledby="standard-title">
      <div class="wrap">
        <div class="section-grid">
          <div class="section-head reveal">
            <p class="section-label">What Arky is</p>
            <h2 id="standard-title">A public protocol for accountable action.</h2>
          </div>
          <div class="definition reveal" style="--reveal-delay: 100ms">
            <p>A minimal public protocol that records who acted, with what evidence, under which policy, and what actually happened.</p>
          </div>
        </div>

        <div class="dim" aria-hidden="true"><span class="dim-label">CORE ARTIFACTS&ensp;·&ensp;TIM &rarr; NOTARY &rarr; KERNEL &rarr; SETTLER &rarr; XR</span></div>
        <div class="spec-register reveal" aria-label="Core artifact register">
          <div class="spec-row">
            <span class="spec-idx">01</span>
            <span class="spec-name"><b>TIM</b><span>Evidence</span></span>
            <span class="spec-desc">Signed, content-addressed evidence: who, what, when.</span>
            <span class="spec-algo">cid = <b>multibase</b>(<b>multihash</b>(<span class="ox">sha2-256</span>, JCS(body)))</span>
          </div>
          <div class="spec-row">
            <span class="spec-idx">02</span>
            <span class="spec-name"><b>Notary</b><span>Witness</span></span>
            <span class="spec-desc">Fixes time, order, and finality; optional chain or log anchor.</span>
            <span class="spec-algo"><span class="ox">merkle-sha256-v1</span> root &middot; inclusion proof</span>
          </div>
          <div class="spec-row">
            <span class="spec-idx">03</span>
            <span class="spec-name"><b>Kernel</b><span>Policy</span></span>
            <span class="spec-desc">Deterministic decision under declared policy packs.</span>
            <span class="spec-algo">eval(assertions, <span class="ox">policy</span>) &rarr; allow / deny</span>
          </div>
          <div class="spec-row">
            <span class="spec-idx">04</span>
            <span class="spec-name"><b>Settler</b><span>Execute</span></span>
            <span class="spec-desc">Runs a verb on a rail: bank, chain, or device.</span>
            <span class="spec-algo">verb(<span class="ox">idempotency-key</span>) on rail</span>
          </div>
          <div class="spec-row">
            <span class="spec-idx">05</span>
            <span class="spec-name"><b>XR</b><span>Receipt</span></span>
            <span class="spec-desc">Signed outcome tied to the decision, rail, and anchors.</span>
            <span class="spec-algo">JWS <span class="ox">Ed25519</span> &middot; RFC 7797 b64:false</span>
          </div>
        </div>
      </div>
    </section>

