<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Arky is a neutral public standard for action and verification across agents, money, chains, and machines. Signed, content-addressed receipts any system can replay.">
  <meta name="color-scheme" content="light">
  <title>Arky - Neutral Accountability Standard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,650&family=Fragment+Mono&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet">
  <style>
    :root {
      --ground: #F3EFE5;
      --lines: #C5BCA8;
      --text: #181612;
      --text-dim: #6B6258;
      --accent: #1E3D5C;
      --accent-soft: rgba(30, 61, 92, 0.06);
      --oxide: #BC4B2A;
      --oxide-soft: rgba(188, 75, 42, 0.08);
      --panel: #FBFAF5;
      --hairline: #D9D1C0;
      --max: 1440px;
      --max-text: 1180px;
      --gutter: 36px;
      --header-h: 76px;
      --font-display: "Fraunces", Georgia, "Times New Roman", serif;
      --font-mono: "Fragment Mono", "SF Mono", "Menlo", "Consolas", monospace;
      --font-body: "Newsreader", "Georgia", "Times New Roman", serif;
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

      /* 8px-modular spacing scale */
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-7: 32px;
      --space-8: 40px;
      --space-9: 48px;
      --space-10: 56px;
      --space-11: 64px;
      --space-12: 72px;
      --space-13: 80px;
      --space-14: 96px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      background:
        radial-gradient(125% 90% at 78% -8%, rgba(30, 61, 92, 0.06), transparent 52%),
        radial-gradient(110% 80% at 8% 4%, rgba(188, 75, 42, 0.04), transparent 46%),
        linear-gradient(192deg, #F7F3EA, #F3EFE5 58%, #EDE8DB),
        var(--ground);
      color: var(--text);
      scroll-behavior: smooth;
    }

    body {
      position: relative;
      min-height: 100vh;
      margin: 0;
      overflow-x: hidden;
      background: transparent;
      color: var(--text);
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.65;
      letter-spacing: 0.002em;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* Fine dot-grid + coarse module grid + blueprint texture, full viewport */
    body::before {
      position: fixed;
      inset: -2px;
      z-index: -3;
      content: "";
      background-image:
        /* coarse module grid */
        linear-gradient(rgba(197, 188, 168, 0.12) 1px, transparent 1px),
        linear-gradient(90deg, rgba(197, 188, 168, 0.12) 1px, transparent 1px),
        /* engineering dot-grid */
        radial-gradient(circle, rgba(197, 188, 168, 0.18) 1px, transparent 1px),
        /* fine sub-grid */
        linear-gradient(rgba(197, 188, 168, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(197, 188, 168, 0.05) 1px, transparent 1px);
      background-size:
        144px 144px,
        144px 144px,
        24px 24px,
        36px 36px,
        36px 36px;
      opacity: 0.72;
      pointer-events: none;
      animation: grid-drift 90s linear infinite;
    }

    /* Paper grain + faint vignette over everything */
    body::after {
      position: fixed;
      inset: 0;
      z-index: -2;
      content: "";
      pointer-events: none;
      opacity: 0.55;
      background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='160'%20height='160'%3E%3Cfilter%20id='n'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.9'%20numOctaves='2'%20stitchTiles='stitch'/%3E%3CfeColorMatrix%20type='saturate'%20values='0'/%3E%3C/filter%3E%3Crect%20width='100%25'%20height='100%25'%20filter='url(%23n)'%20opacity='0.04'/%3E%3C/svg%3E"),
        radial-gradient(120% 120% at 50% 40%, transparent 62%, rgba(60, 50, 38, 0.05));
    }

    @keyframes grid-drift {
      to {
        background-position: 144px 144px, 144px 144px, 24px 24px, 36px 36px, 36px 36px;
      }
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    a:focus-visible,
    button:focus-visible {
      outline: 1px solid var(--accent);
      outline-offset: 4px;
    }

    button {
      font: inherit;
      letter-spacing: 0;
    }

    .skip-link {
      position: fixed;
      left: var(--space-4);
      top: var(--space-4);
      z-index: 10;
      transform: translateY(-140%);
      border: 1px solid var(--hairline);
      border-radius: 4px;
      background: var(--panel);
      color: var(--text);
      padding: var(--space-2) var(--space-4);
    }

    .skip-link:focus {
      transform: translateY(0);
    }

    /* Full-document circuit board: an absolutely-positioned div spanning the
       entire page height (top:0/bottom:0 against the relatively-positioned
       body), tiled with a dense schematic SVG so the board runs continuously
       behind every section. A div (not an inline SVG) is used because it
       reliably fills top/bottom; inline SVGs collapse without intrinsic size. */
    .blueprint-field {
      position: fixed;
      inset: 0;
      z-index: -1;
      opacity: 0.4;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%221600%22%20height%3D%22900%22%20viewBox%3D%220%200%201600%20900%22%20preserveAspectRatio%3D%22xMidYMid%20slice%22%3E%3Cpath%20d%3D%22M-20%20120H260L320%2070H520L580%20120H980L1050%2060H1340L1410%20130H1620%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221.2%22%20stroke-opacity%3D%220.2%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M-20%20470H300L360%20410H760L820%20470H1180L1260%20410H1620%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221.2%22%20stroke-opacity%3D%220.2%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M-20%20780H360L430%20720H720L800%20790H1160L1240%20730H1620%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221.2%22%20stroke-opacity%3D%220.2%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M-20%20300H320L390%20240H700L770%20300C900%20160%201100%20160%201230%20300S1500%20440%201620%20300%22%20fill%3D%22none%22%20stroke%3D%22%23BC4B2A%22%20stroke-width%3D%221.1%22%20stroke-opacity%3D%220.22%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M320%2070V300%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M580%20120V470%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M820%20300V470%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M1050%2060V300%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M1260%20300V470%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M430%20470V720%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M1160%20470V780%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M700%20300V780%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16000000000000003%22%20stroke-linecap%3D%22round%22%2F%3E%3Crect%20x%3D%22180%22%20y%3D%22520%22%20width%3D%22200%22%20height%3D%22150%22%20rx%3D%224%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16%22%2F%3E%3Crect%20x%3D%22640%22%20y%3D%22150%22%20width%3D%22240%22%20height%3D%22150%22%20rx%3D%224%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16%22%2F%3E%3Crect%20x%3D%221080%22%20y%3D%22540%22%20width%3D%22240%22%20height%3D%22160%22%20rx%3D%224%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16%22%2F%3E%3Crect%20x%3D%221320%22%20y%3D%22180%22%20width%3D%22180%22%20height%3D%22150%22%20rx%3D%224%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16%22%2F%3E%3Crect%20x%3D%22420%22%20y%3D%22560%22%20width%3D%2290%22%20height%3D%2290%22%20rx%3D%224%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.16%22%2F%3E%3Cpath%20d%3D%22M520%20470h10l6-12h6l6%2012h6l6-12h6l6%2012h10%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.2%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M980%20120h18M1004%20108v24M1016%20108v24M1026%20120h18%22%20fill%3D%22none%22%20stroke%3D%22%231E3D5C%22%20stroke-width%3D%221%22%20stroke-opacity%3D%220.2%22%20stroke-linecap%3D%22round%22%2F%3E%3Ccircle%20cx%3D%22260%22%20cy%3D%22120%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22520%22%20cy%3D%22120%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22980%22%20cy%3D%22120%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%221340%22%20cy%3D%22120%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22300%22%20cy%3D%22470%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22760%22%20cy%3D%22470%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%221180%22%20cy%3D%22470%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22360%22%20cy%3D%22780%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22720%22%20cy%3D%22780%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%221160%22%20cy%3D%22780%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22320%22%20cy%3D%22300%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22700%22%20cy%3D%22300%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%221230%22%20cy%3D%22300%22%20r%3D%223%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.32%22%2F%3E%3Ccircle%20cx%3D%22390%22%20cy%3D%22300%22%20r%3D%223%22%20fill%3D%22%23BC4B2A%22%20fill-opacity%3D%220.4%22%2F%3E%3Ccircle%20cx%3D%22770%22%20cy%3D%22300%22%20r%3D%223%22%20fill%3D%22%23BC4B2A%22%20fill-opacity%3D%220.4%22%2F%3E%3Ctext%20x%3D%2270%22%20y%3D%22108%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.22%22%20font-family%3D%22monospace%22%20font-size%3D%2211%22%20letter-spacing%3D%221%22%3EEd25519%3C%2Ftext%3E%3Ctext%20x%3D%221090%22%20y%3D%22528%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.22%22%20font-family%3D%22monospace%22%20font-size%3D%2211%22%20letter-spacing%3D%221%22%3Esha2-256%3C%2Ftext%3E%3Ctext%20x%3D%22650%22%20y%3D%22140%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.22%22%20font-family%3D%22monospace%22%20font-size%3D%2211%22%20letter-spacing%3D%221%22%3Emerkle.root%3C%2Ftext%3E%3Ctext%20x%3D%22430%22%20y%3D%22548%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.22%22%20font-family%3D%22monospace%22%20font-size%3D%2211%22%20letter-spacing%3D%221%22%3EJWS.b64%3Afalse%3C%2Ftext%3E%3Ctext%20x%3D%221330%22%20y%3D%22168%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.22%22%20font-family%3D%22monospace%22%20font-size%3D%2211%22%20letter-spacing%3D%221%22%3Efinality.N3%3C%2Ftext%3E%3Ctext%20x%3D%22185%22%20y%3D%22508%22%20fill%3D%22%231E3D5C%22%20fill-opacity%3D%220.22%22%20font-family%3D%22monospace%22%20font-size%3D%2211%22%20letter-spacing%3D%221%22%3Estatus.success%3C%2Ftext%3E%3C%2Fsvg%3E");
      background-repeat: no-repeat;
      background-size: cover;
      background-position: center;
    }

    /* Via dots inside the hero data-flow stage SVG */
    .bp-via { fill: var(--lines); opacity: 0.4; }

    .wrap {
      width: min(100% - calc(var(--gutter) * 2), var(--max));
      margin: 0 auto;
    }

    .wrap-text {
      width: min(100% - calc(var(--gutter) * 2), var(--max-text));
      margin: 0 auto;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 6;
      border-bottom: 1px solid rgba(210, 203, 186, 0.5);
      background: rgba(247, 243, 234, 0.82);
      backdrop-filter: blur(20px);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: var(--header-h);
      gap: var(--space-6);
    }

    .brand {
      display: inline-flex;
      align-items: center;
      min-width: 0;
      gap: var(--space-3);
      color: var(--text);
    }

    .brand-mark {
      display: grid;
      width: 34px;
      height: 34px;
      flex-shrink: 0;
      place-items: center;
      color: var(--oxide);
      transition: transform 320ms var(--ease-spring);
    }

    .brand:hover .brand-mark {
      transform: rotate(-6deg);
    }

    .brand-mark svg {
      width: 26px;
      height: 26px;
    }

    .brand-text {
      display: flex;
      flex-direction: column;
      line-height: 1;
    }

    .brand-name {
      font-family: var(--font-display);
      font-size: 1.32rem;
      font-weight: 640;
      letter-spacing: -0.02em;
    }

    .brand-sub {
      margin-top: 3px;
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .nav a {
      position: relative;
      color: var(--text-dim);
      font-size: 0.95rem;
      padding: var(--space-2) var(--space-3);
      transition: color 200ms var(--ease-out);
    }

    .nav a:not(.nav-cta)::after {
      content: "";
      position: absolute;
      left: var(--space-3);
      right: var(--space-3);
      bottom: 4px;
      height: 1px;
      background: var(--oxide);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 240ms var(--ease-out);
    }

    .nav a:not(.nav-cta):hover {
      color: var(--text);
    }

    .nav a:not(.nav-cta):hover::after {
      transform: scaleX(1);
    }

    .nav-cta {
      margin-left: var(--space-2);
      display: inline-flex;
      align-items: center;
      height: 38px;
      border: 1px solid var(--accent);
      border-radius: 4px;
      background: var(--accent);
      color: #F4F1E8 !important;
      font-weight: 540;
      padding: 0 var(--space-4) !important;
      transition: background 220ms var(--ease-out), box-shadow 220ms var(--ease-out);
    }

    .nav-cta:hover {
      background: #162e45;
      box-shadow: 0 2px 14px rgba(30, 61, 92, 0.22);
    }

    @media (max-width: 880px) {
      .brand-sub {
        letter-spacing: 0.2em;
      }
    }

    /* ============ FULL-BLEED HERO STAGE ============ */
    .hero {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: calc(100svh - var(--header-h));
      padding: clamp(var(--space-7), 6vh, var(--space-12)) 0 clamp(var(--space-6), 4vh, var(--space-9));
    }

    /* Veil: softly mute the background circuit behind the hero so the
       foreground diagrams (actor-network + data-flow stage) read cleanly. */
    .hero::before {
      content: "";
      position: absolute;
      inset: -10% -20% 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(62% 60% at 72% 42%, var(--ground) 30%, rgba(243, 239, 229, 0.7) 52%, transparent 78%),
        radial-gradient(70% 55% at 24% 40%, var(--ground) 24%, rgba(243, 239, 229, 0.55) 50%, transparent 76%);
    }

    /* Hero top band: copy left, live actor-network right */
    .hero-top {
      position: relative;
      z-index: 3;
      width: min(100% - calc(var(--gutter) * 2), var(--max));
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      align-items: center;
      gap: var(--space-9);
    }

    .hero-copy {
      position: relative;
      z-index: 3;
      min-width: 0;
    }

    /* ============ HERO ACTOR-NETWORK ============ */
    .hero-net {
      position: relative;
      min-width: 0;
      aspect-ratio: 1 / 1;
      width: 100%;
      max-width: 540px;
      margin-left: auto;
    }

    .hero-net svg {
      display: block;
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .net-grid {
      fill: none;
      stroke: var(--lines);
      stroke-width: 0.6;
      opacity: 0.3;
      vector-effect: non-scaling-stroke;
    }

    .net-orbit {
      fill: none;
      stroke: var(--lines);
      stroke-width: 0.8;
      opacity: 0.32;
      stroke-dasharray: 3 6;
      vector-effect: non-scaling-stroke;
    }

    .net-orbit.spin {
      transform-box: fill-box;
      transform-origin: center;
      animation: net-orbit-spin 64s linear infinite;
    }

    @keyframes net-orbit-spin {
      to { transform: rotate(360deg); }
    }

    /* Spokes from each actor to the central hub */
    .net-spoke {
      fill: none;
      stroke: var(--lines);
      stroke-width: 1;
      opacity: 0.4;
      vector-effect: non-scaling-stroke;
    }

    .net-spoke-live {
      fill: none;
      stroke-linecap: round;
      stroke-width: 1.4;
      vector-effect: non-scaling-stroke;
      stroke-dasharray: 14 220;
      opacity: 0.7;
    }

    .net-spoke-live.inbound { stroke: var(--accent); animation: net-flow 3.6s linear infinite; }
    .net-spoke-live.outbound { stroke: var(--oxide); animation: net-flow-rev 3.6s linear infinite; }

    @keyframes net-flow { to { stroke-dashoffset: -234; } }
    @keyframes net-flow-rev { to { stroke-dashoffset: 234; } }

    /* Domain actor node */
    .net-node {
      cursor: default;
    }

    .net-node .net-chip {
      fill: rgba(251, 250, 245, 0.96);
      stroke: var(--lines);
      stroke-width: 1;
      vector-effect: non-scaling-stroke;
      transition: stroke 280ms var(--ease-out), fill 280ms var(--ease-out);
    }

    .net-node .net-glyph {
      fill: none;
      stroke: var(--accent);
      stroke-width: 1.6;
      stroke-linecap: round;
      stroke-linejoin: round;
      opacity: 0.8;
      vector-effect: non-scaling-stroke;
      transition: stroke 280ms var(--ease-out), opacity 280ms var(--ease-out);
    }

    .net-node .net-name {
      fill: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .net-node.lit .net-chip { stroke: var(--oxide); fill: var(--oxide-soft); }
    .net-node.lit .net-glyph { stroke: var(--oxide); opacity: 1; }
    .net-node.lit .net-name { fill: var(--oxide); }

    /* Central Arky hub */
    .net-hub-ring {
      fill: rgba(251, 250, 245, 0.96);
      stroke: var(--accent);
      stroke-width: 1.4;
      vector-effect: non-scaling-stroke;
    }

    .net-hub-pulse {
      fill: none;
      stroke: var(--accent);
      stroke-width: 1;
      opacity: 0.5;
      vector-effect: non-scaling-stroke;
      transform-box: fill-box;
      transform-origin: center;
      animation: net-hub-pulse 3.6s var(--ease-out) infinite;
    }

    @keyframes net-hub-pulse {
      0% { transform: scale(1); opacity: 0.5; }
      70% { transform: scale(2.1); opacity: 0; }
      100% { transform: scale(2.1); opacity: 0; }
    }

    .net-hub-mark {
      fill: none;
      stroke: var(--accent);
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      vector-effect: non-scaling-stroke;
    }

    .net-hub-label {
      fill: var(--accent);
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.02em;
      text-anchor: middle;
    }

    /* Travelling signal packets */
    .net-packet {
      fill: var(--oxide);
      filter: drop-shadow(0 0 6px rgba(188, 75, 42, 0.5));
    }

    .net-packet.evidence { fill: var(--accent); filter: drop-shadow(0 0 6px rgba(30, 61, 92, 0.45)); }

    .net-readout {
      position: absolute;
      left: 0;
      bottom: -2px;
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      border: 1px solid var(--hairline);
      border-radius: 3px;
      background: rgba(251, 250, 245, 0.9);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.04em;
      padding: var(--space-1) var(--space-3);
      white-space: nowrap;
    }

    .net-readout b { color: var(--oxide); font-weight: 500; }

    @media (prefers-reduced-motion: reduce) {
      .net-orbit.spin,
      .net-spoke-live,
      .net-hub-pulse { animation: none; }
      .net-spoke-live { stroke-dasharray: none; opacity: 0.5; }
    }

    .kicker {
      display: inline-flex;
      align-items: center;
      gap: var(--space-4);
      margin: 0 0 var(--space-6);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .kicker::before {
      display: block;
      width: 48px;
      height: 1px;
      background: linear-gradient(90deg, var(--oxide), rgba(188, 75, 42, 0.2));
      content: "";
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1,
    h2,
    h3 {
      font-family: var(--font-display);
      font-optical-sizing: auto;
    }

    h1 {
      margin-bottom: var(--space-5);
      color: var(--text);
      font-size: clamp(4.5rem, 13vw, 12rem);
      font-weight: 650;
      letter-spacing: -0.03em;
      line-height: 0.84;
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.7), 0 -1px 1px rgba(0, 0, 0, 0.06);
    }

    h1 .h1-mark {
      position: relative;
      display: inline-block;
      padding-right: 0.1em;
    }

    /* Hairline registration ticks flanking the monogram */
    h1 .h1-mark::after {
      position: absolute;
      right: -0.04em;
      bottom: 0.14em;
      width: 0.55ch;
      height: 0.55ch;
      border-right: 2px solid var(--oxide);
      border-bottom: 2px solid var(--oxide);
      opacity: 0.6;
      content: "";
    }

    .tagline {
      max-width: 32ch;
      margin-top: var(--space-9);
      margin-bottom: var(--space-5);
      color: var(--text);
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 2.2vw, 2.2rem);
      font-weight: 400;
      line-height: 1.22;
    }

    .subline {
      max-width: 58ch;
      margin-bottom: var(--space-7);
      color: var(--text-dim);
      font-family: var(--font-body);
      font-size: clamp(1.05rem, 1.15vw, 1.22rem);
      line-height: 1.55;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-3);
      margin-top: var(--space-7);
    }

    .button {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 48px;
      border: 1px solid var(--hairline);
      border-radius: 3px;
      background: var(--panel);
      color: var(--text);
      padding: 0 var(--space-5);
      font-size: 1rem;
      font-weight: 520;
      line-height: 1;
      letter-spacing: 0.006em;
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.55);
      transition: border-color 220ms var(--ease-out), color 220ms var(--ease-out), background 220ms var(--ease-out), transform 220ms var(--ease-out), box-shadow 220ms var(--ease-out);
    }

    .button:hover {
      border-color: rgba(30, 61, 92, 0.45);
      color: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    }

    .button.primary {
      border-color: var(--accent);
      background: var(--accent);
      color: #F4F1E8;
      box-shadow: 0 2px 16px rgba(30, 61, 92, 0.2);
    }

    .button.primary:hover {
      background: #162e45;
      color: #fff;
      box-shadow: 0 4px 20px rgba(30, 61, 92, 0.28);
    }

    /* Full-bleed stage: the protocol flow as the hero centerpiece */
    .hero-stage {
      position: relative;
      z-index: 2;
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-top: clamp(var(--space-7), 6vh, var(--space-11));
      padding: 0;
    }

    /* Mute the background circuit behind the full-bleed data-flow stage so
       the diagram reads cleanly; fades out to the edges. */
    .hero-stage::before {
      content: "";
      position: absolute;
      inset: -16% 0;
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(58% 92% at 50% 50%, var(--ground) 42%, rgba(243, 239, 229, 0.66) 64%, transparent 88%);
    }

    .hero-stage svg.stage-svg {
      display: block;
      width: 100%;
      height: clamp(300px, 44vh, 480px);
    }

    .stage-edge-fade {
      position: absolute;
      inset: 0;
      z-index: 3;
      pointer-events: none;
      background: linear-gradient(90deg, var(--ground), transparent 10%, transparent 90%, var(--ground));
    }

    /* Floating controls anchored to the readable column over the wide stage */
    .stage-controls {
      width: min(100% - calc(var(--gutter) * 2), var(--max));
      margin: calc(-1 * var(--space-10)) auto 0;
      position: relative;
      z-index: 4;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
    }

    .schematic-line {
      fill: none;
      stroke: var(--lines);
      stroke-width: 1;
      vector-effect: non-scaling-stroke;
      opacity: 0.6;
    }

    .schematic-faint {
      fill: none;
      stroke: var(--lines);
      stroke-width: 0.6;
      opacity: 0.4;
      vector-effect: non-scaling-stroke;
    }

    .schematic-oxide {
      fill: none;
      stroke: var(--oxide);
      stroke-width: 0.7;
      opacity: 0.35;
      vector-effect: non-scaling-stroke;
    }

    .node-box {
      fill: rgba(251, 250, 245, 0.94);
      stroke: var(--lines);
      stroke-width: 1;
      vector-effect: non-scaling-stroke;
      transition: stroke 260ms var(--ease-out), fill 260ms var(--ease-out);
    }

    .node-label {
      fill: var(--text);
      font-family: var(--font-mono);
      font-size: 14px;
      font-weight: 400;
      letter-spacing: 0.06em;
    }

    .node-role {
      fill: var(--text-dim);
      font-family: var(--font-body);
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .node-pin {
      stroke: var(--lines);
      stroke-width: 0.9;
      opacity: 0.45;
      vector-effect: non-scaling-stroke;
    }

    .flow-node[data-active="true"] .node-box {
      fill: rgba(30, 61, 92, 0.06);
      stroke: var(--accent);
      stroke-width: 1.5;
    }

    .flow-node[data-active="true"] .node-label {
      fill: var(--accent);
    }

    .flow-node[data-active="true"] .node-pin {
      stroke: var(--accent);
      opacity: 0.75;
    }

    .flow-node {
      cursor: pointer;
    }

    .flow-node:focus-visible {
      outline: none;
    }

    .flow-node:focus-visible .node-box {
      stroke: var(--oxide);
      stroke-width: 1.8;
    }

    .flow-node:hover .node-box {
      stroke: rgba(30, 61, 92, 0.5);
    }

    .live-route {
      fill: none;
      stroke: var(--oxide);
      stroke-linecap: round;
      stroke-width: 2.2;
      filter: drop-shadow(0 0 8px rgba(188, 75, 42, 0.28));
      vector-effect: non-scaling-stroke;
    }

    .signal-dot {
      fill: var(--oxide);
      filter: drop-shadow(0 0 10px rgba(188, 75, 42, 0.55));
    }

    .signal-halo {
      fill: var(--oxide);
      opacity: 0.16;
    }

    .readout {
      display: inline-flex;
      align-items: center;
      gap: var(--space-4);
      border: 1px solid var(--hairline);
      border-radius: 3px;
      background: rgba(251, 250, 245, 0.9);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.74rem;
      letter-spacing: 0.04em;
      padding: var(--space-3) var(--space-4);
    }

    .readout strong {
      color: var(--accent);
      font-weight: 500;
    }

    .readout .receipt {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      color: var(--oxide);
    }

    .readout .receipt::before {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--oxide);
      content: "";
    }

    .stage-meta {
      display: flex;
      flex: 1 1 320px;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-4);
      min-width: 0;
    }

    .depth-toggle {
      display: inline-flex;
      border: 1px solid var(--hairline);
      border-radius: 3px;
      background: rgba(251, 250, 245, 0.9);
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
      padding: var(--space-1);
    }

    .depth-btn {
      border: 0;
      border-radius: 3px;
      background: transparent;
      color: var(--text-dim);
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      padding: var(--space-2) var(--space-4);
      text-transform: uppercase;
      transition: color 200ms var(--ease-out), background 200ms var(--ease-out);
    }

    .depth-btn[aria-pressed="true"] {
      background: var(--accent);
      color: #F4F1E8;
    }

    .stage-desc {
      width: min(100% - calc(var(--gutter) * 2), var(--max));
      margin: var(--space-5) auto 0;
      position: relative;
      z-index: 4;
      min-height: 1.6em;
      color: var(--text);
      font-family: var(--font-body);
      font-size: 1.02rem;
      line-height: 1.45;
      opacity: 1;
      transition: opacity 260ms ease, transform 260ms ease;
    }

    .stage-desc.is-swapping {
      opacity: 0;
      transform: translateY(5px);
    }

    .stage-desc code {
      color: var(--oxide);
      font-family: var(--font-mono);
      font-size: 0.86em;
    }

    .band {
      border-top: 1px solid var(--hairline);
    }

    .section {
      position: relative;
      padding: var(--space-14) 0;
    }

    /* Two-column section intro: heading block left, supporting prose right.
       Top-aligned; the right prose is nudged down to start level with the
       h2 (clearing the eyebrow label) so it never floats mid-column. */
    .section-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.62fr) minmax(0, 1fr);
      align-items: start;
      gap: var(--space-7) var(--space-12);
      margin-bottom: var(--space-9);
    }

    .section-grid > * {
      margin: 0;
    }

    /* The heading column owns its internal rhythm */
    .section-head > * {
      margin: 0;
    }

    .section-head .section-label {
      margin-bottom: var(--space-4);
    }

    .section-head h2 {
      margin-bottom: 0;
    }

    /* Align the right-column prose with the h2, not the eyebrow above it.
       Offset ~= section-label line-height (0.7rem x 1.65) + its bottom margin. */
    .section-grid > .lead,
    .section-grid > .definition {
      margin-top: calc(0.7rem * 1.65 + var(--space-4));
    }

    @media (max-width: 1080px) {
      .section-grid > .lead,
      .section-grid > .definition {
        margin-top: 0;
      }
    }

    .section-label {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .section-label::before {
      width: 26px;
      height: 1px;
      background: var(--oxide);
      content: "";
    }

    h2 {
      max-width: 16ch;
      margin-bottom: var(--space-5);
      font-weight: 620;
      letter-spacing: -0.015em;
      line-height: 1.06;
    }

    /* Scroll-reveal: elements rise and fade in when scrolled into view */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 680ms var(--ease-out), transform 680ms var(--ease-out);
      transition-delay: var(--reveal-delay, 0ms);
    }

    .reveal.is-in {
      opacity: 1;
      transform: none;
    }

    /* Page-load orchestrated reveal for above-fold hero elements */
    @media (prefers-reduced-motion: no-preference) {
      .reveal.hero-load {
        animation: hero-rise 760ms var(--ease-out) var(--reveal-delay, 0ms) both;
        opacity: 0;
        transform: translateY(24px);
      }
    }

    @keyframes hero-rise {
      to {
        opacity: 1;
        transform: none;
      }
    }

    .lead {
      max-width: 720px;
      margin-bottom: 0;
      color: var(--text-dim);
      font-family: var(--font-body);
      font-size: 1.08rem;
      line-height: 1.55;
    }

    .definition {
      position: relative;
      border: 1px solid var(--hairline);
      border-left: 2px solid rgba(30, 61, 92, 0.5);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 1.32rem;
      line-height: 1.5;
      padding: var(--space-6) var(--space-6) var(--space-6) var(--space-7);
      margin: 0;
    }

    .definition::before {
      position: absolute;
      top: -0.6em;
      left: var(--space-6);
      background: var(--ground);
      padding: 0 var(--space-2);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.58rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      line-height: 1;
      content: "DEFINITION";
    }

    .definition::after {
      position: absolute;
      right: -0.6em;
      bottom: var(--space-6);
      width: 10px;
      height: 10px;
      border-right: 2px solid var(--oxide);
      border-bottom: 2px solid var(--oxide);
      opacity: 0.45;
      content: "";
    }

    /* Dimension bar — blueprint measured-drawing annotation.
       Sits directly above a content grid; the section-grid above it
       already supplies the top gap, so it only owns its bottom gap. */
    .dim {
      display: flex;
      align-items: center;
      gap: 0;
      margin: 0 0 var(--space-5);
    }

    /* When a dim divider follows another content block (e.g. metric-row),
       restore a top gap so it doesn't collide. */
    .metric-row + .dim {
      margin-top: var(--space-9);
    }

    .dim::before,
    .dim::after {
      flex: 1;
      height: 1px;
      background: var(--lines);
      opacity: 0.4;
      content: "";
    }

    .dim-label {
      flex-shrink: 0;
      padding: 0 var(--space-3);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      line-height: 1;
    }

    /* Spec register — a measured-drawing data table of the core artifacts */
    .spec-register {
      margin-top: 0;
      border: 1px solid var(--hairline);
      border-radius: 5px;
      overflow: hidden;
      background: rgba(251, 250, 245, 0.55);
    }

    .spec-row {
      display: grid;
      grid-template-columns: 26px minmax(120px, 0.9fr) minmax(0, 1.5fr) minmax(0, 1.3fr);
      align-items: baseline;
      gap: var(--space-5);
      padding: var(--space-5) var(--space-6);
      border-bottom: 1px solid var(--hairline);
      transition: background 220ms ease;
    }

    .spec-row:last-child {
      border-bottom: 0;
    }

    .spec-row:hover {
      background: var(--panel);
    }

    .spec-idx {
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.06em;
      opacity: 0.7;
    }

    .spec-name {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .spec-name b {
      color: var(--text);
      font-family: var(--font-display);
      font-size: 1.04rem;
      font-weight: 560;
      letter-spacing: -0.006em;
    }

    .spec-name span {
      color: var(--text-dim);
      font-family: var(--font-body);
      font-size: 0.78rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .spec-desc {
      color: var(--text-dim);
      font-size: 0.92rem;
      line-height: 1.45;
    }

    .spec-algo {
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 0.74rem;
      line-height: 1.5;
      letter-spacing: 0.01em;
    }

    .spec-algo b {
      color: var(--accent);
      font-weight: 500;
    }

    .spec-algo .ox {
      color: var(--oxide);
    }

    .path-card h3 {
      margin-bottom: var(--space-2);
      color: var(--text);
      font-family: var(--font-display);
      font-size: 1.08rem;
      font-weight: 560;
      letter-spacing: -0.008em;
      line-height: 1.22;
    }

    .path-card h3::after {
      display: block;
      width: 36px;
      height: 1px;
      margin-top: var(--space-3);
      background: var(--lines);
      opacity: 0.38;
      content: "";
    }

    .path-card > p:not(.claim) {
      margin-top: var(--space-3);
      margin-bottom: 0;
      color: var(--text-dim);
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .path-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-5);
      margin-top: 0;
    }

    .path-card {
      position: relative;
      display: flex;
      flex-direction: column;
      border: 1px solid var(--hairline);
      border-top: 2px solid var(--accent);
      border-radius: 5px;
      background: rgba(251, 250, 245, 0.7);
      padding: var(--space-6);
      transition: border-color 240ms ease, transform 240ms var(--ease-out), box-shadow 240ms ease;
    }

    .path-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 36px rgba(0, 0, 0, 0.06);
    }

    /* Card links rendered as clear, labelled link rows with an arrow */
    .path-links {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-4);
      margin-top: auto;
      padding-top: var(--space-5);
    }

    .path-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      color: var(--accent);
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-weight: 560;
      border-bottom: 1px solid rgba(30, 61, 92, 0.28);
      padding-bottom: 2px;
      transition: color 200ms ease, border-color 200ms ease, gap 200ms var(--ease-out);
    }

    .path-link::after {
      content: "\2192";
      font-size: 1.05em;
      line-height: 1;
    }

    .path-link:hover {
      color: var(--oxide);
      border-color: var(--oxide);
      gap: var(--space-3);
    }

    .terminal {
      margin-top: auto;
      border: 1px solid var(--hairline);
      border-radius: 4px;
      background: #EDE9DF;
      overflow: hidden;
    }

    .terminal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      min-height: 42px;
      border-bottom: 1px solid var(--hairline);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      padding: 0 var(--space-4);
    }

    .copy-command {
      border: 1px solid var(--hairline);
      border-radius: 3px;
      background: transparent;
      color: var(--text-dim);
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      padding: var(--space-1) var(--space-2);
      transition: color 200ms ease, border-color 200ms ease;
    }

    .copy-command:hover {
      border-color: rgba(30, 61, 92, 0.36);
      color: var(--accent);
    }

    pre {
      margin: 0;
      overflow-x: auto;
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 0.88rem;
      line-height: 1.7;
      padding: var(--space-4) var(--space-4);
    }

    code {
      font-family: var(--font-mono);
    }

    /* Conformance ledger — pass/fail levels as a measured data table */
    .ledger {
      margin-top: 0;
      border: 1px solid var(--hairline);
      border-radius: 5px;
      overflow: hidden;
      background: rgba(251, 250, 245, 0.55);
    }

    .ledger-head,
    .ledger-row {
      display: grid;
      grid-template-columns: minmax(120px, 1fr) minmax(0, 2.2fr) 88px 120px;
      align-items: center;
      gap: var(--space-5);
      padding: var(--space-4) var(--space-6);
    }

    .ledger-head {
      border-bottom: 1px solid var(--hairline);
      background: rgba(30, 61, 92, 0.03);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .ledger-row {
      border-bottom: 1px solid var(--hairline);
      transition: background 220ms ease;
    }

    .ledger-row:last-child {
      border-bottom: 0;
    }

    .ledger-row:hover {
      background: var(--panel);
    }

    .ledger-suite {
      color: var(--text);
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 560;
    }

    .ledger-levels {
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.74rem;
      letter-spacing: 0.02em;
      line-height: 1.5;
    }

    .ledger-count {
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.86rem;
      font-weight: 500;
      text-align: right;
    }

    .pass-pill {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      justify-self: end;
      border: 1px solid rgba(30, 61, 92, 0.28);
      border-radius: 3px;
      background: rgba(30, 61, 92, 0.04);
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.08em;
      padding: var(--space-1) var(--space-2);
      text-transform: uppercase;
    }

    .pass-pill::before {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
      content: "";
    }

    .pass-pill.pending {
      border-color: rgba(188, 75, 42, 0.32);
      background: rgba(188, 75, 42, 0.05);
      color: var(--oxide);
    }

    .pass-pill.pending::before {
      background: var(--oxide);
    }

    /* Top-line conformance metrics */
    .metric-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--hairline);
      border-radius: 5px;
      overflow: hidden;
      background: var(--hairline);
      margin-top: 0;
    }

    .metric {
      position: relative;
      background: rgba(251, 250, 245, 0.6);
      padding: var(--space-6);
    }

    .metric::before {
      position: absolute;
      left: 0;
      top: var(--space-5);
      bottom: var(--space-5);
      width: 1px;
      background: var(--lines);
      opacity: 0.22;
      content: "";
    }

    .metric .num {
      display: block;
      color: var(--text);
      font-family: var(--font-display);
      font-size: 2.6rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .metric .num em {
      color: var(--oxide);
      font-style: normal;
    }

    .metric .cap {
      display: block;
      margin-top: var(--space-3);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      line-height: 1.5;
    }

    .claim {
      display: inline-flex;
      margin-bottom: var(--space-5);
      border: 1px solid rgba(30, 61, 92, 0.3);
      border-radius: 3px;
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      padding: var(--space-1) var(--space-2);
    }

    .domain-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      border: 1px solid var(--hairline);
      background: var(--hairline);
      margin-top: 0;
    }

    .domain {
      min-height: 172px;
      background: rgba(251, 250, 245, 0.5);
      padding: var(--space-6);
      transition: background 240ms ease;
    }

    .domain:hover {
      background: var(--panel);
    }

    .domain svg {
      display: block;
      width: 44px;
      height: 44px;
      margin-bottom: var(--space-5);
      color: var(--accent);
      opacity: 0.7;
      transition: color 240ms ease, opacity 240ms ease;
    }

    .domain:hover svg {
      color: var(--oxide);
      opacity: 1;
    }

    .domain h3 {
      margin-bottom: var(--space-2);
      color: var(--text);
      font-family: var(--font-display);
      font-size: 1.02rem;
      letter-spacing: -0.005em;
    }

    .domain p {
      margin-bottom: 0;
      color: var(--text-dim);
      font-family: var(--font-body);
      font-size: 0.92rem;
      line-height: 1.45;
    }

    .repo-map {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: var(--space-2);
      margin-top: var(--space-7);
    }

    .repo-map a {
      border: 1px solid var(--hairline);
      border-radius: 3px;
      background: rgba(251, 250, 245, 0.48);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.74rem;
      letter-spacing: 0.04em;
      padding: var(--space-3);
      transition: color 200ms ease, border-color 200ms ease;
    }

    .repo-map a:hover {
      border-color: rgba(30, 61, 92, 0.28);
      color: var(--text);
    }

    .site-footer {
      border-top: 1px solid var(--hairline);
      padding: var(--space-7) 0;
    }

    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-5);
    }

    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-4);
    }

    .footer-links a:hover {
      color: var(--oxide);
    }

    .drawing-block {
      position: fixed;
      bottom: var(--space-5);
      right: var(--space-5);
      z-index: 3;
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      border-radius: 2px;
      background: rgba(247, 243, 234, 0.76);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      padding: var(--space-1) var(--space-3);
      pointer-events: none;
      user-select: none;
    }

    .drawing-rev {
      color: var(--oxide);
    }

    @media (max-width: 1080px) {
      :root {
        --gutter: 24px;
      }

      .hero-top {
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
        gap: var(--space-7);
      }

      .hero-net {
        max-width: 380px;
      }

      .section-grid {
        grid-template-columns: 1fr;
        gap: var(--space-7);
      }

      .spec-row {
        grid-template-columns: 22px minmax(96px, 0.8fr) minmax(0, 1.4fr);
        gap: var(--space-4);
      }

      .spec-row .spec-algo {
        grid-column: 2 / -1;
        padding-top: var(--space-1);
      }

      .ledger-head,
      .ledger-row {
        grid-template-columns: minmax(96px, 1fr) minmax(0, 2fr) 96px;
      }

      .ledger-head span:nth-child(3),
      .ledger-count {
        display: none;
      }

      .domain-list,
      .repo-map {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      :root {
        --header-h: 60px;
        --gutter: 18px;
      }

      .header-inner {
        min-height: var(--header-h);
      }

      .nav a:not(.nav-cta) {
        display: none;
      }

      .nav-cta {
        margin-left: 0;
        height: 34px;
        font-size: 0.88rem;
      }

      .hero {
        min-height: auto;
        padding: var(--space-7) 0 var(--space-8);
      }

      .hero-top {
        grid-template-columns: 1fr;
        gap: var(--space-8);
      }

      .hero-net {
        order: 2;
        max-width: 320px;
        margin: 0 auto;
      }

      h1 {
        font-size: clamp(3.2rem, 11vw, 5rem);
      }

      .tagline {
        font-size: 1.25rem;
      }

      .subline {
        margin-bottom: var(--space-6);
      }

      .hero-actions {
        margin-top: var(--space-6);
      }

      .hero-stage svg.stage-svg {
        height: 300px;
      }

      .stage-controls {
        flex-direction: column;
        align-items: stretch;
        margin-top: calc(-1 * var(--space-8));
      }

      .readout {
        font-size: 0.7rem;
      }

      .section {
        padding: var(--space-11) 0;
      }

      .definition {
        font-size: 1.14rem;
        padding: var(--space-5) var(--space-4);
        border-left-width: 1px;
      }

      .definition::after {
        display: none;
      }

      .path-grid,
      .metric-row,
      .domain-list,
      .repo-map {
        grid-template-columns: 1fr;
      }

      .spec-row {
        grid-template-columns: 22px 1fr;
      }

      .spec-row .spec-desc,
      .spec-row .spec-algo {
        grid-column: 2 / -1;
      }

      .ledger-head {
        display: none;
      }

      .ledger-row {
        grid-template-columns: 1fr auto;
        row-gap: var(--space-2);
        align-items: start;
      }

      .ledger-levels {
        grid-column: 1 / -1;
      }

      .ledger-count {
        display: none;
      }

      .metric .num {
        font-size: 2.2rem;
      }

      .footer-inner {
        align-items: flex-start;
        flex-direction: column;
        gap: var(--space-4);
      }

      *,
      *::before,
      *::after {
        scroll-behavior: auto !important;
        transition-duration: 0.001ms !important;
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
      }
    }
  </style>
  <noscript>
    <style>
      .reveal { opacity: 1 !important; transform: none !important; }
      .hero-load { animation: none !important; opacity: 1 !important; transform: none !important; }
    </style>
  </noscript>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <div class="blueprint-field" aria-hidden="true"></div>

  <header class="site-header">
    <div class="wrap header-inner">
      <a class="brand" href="#top" aria-label="Arky Foundation home">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none">
            <path d="M16 5L26 27H6L16 5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
            <path d="M11 22h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
          </svg>
        </span>
        <span class="brand-text">
          <span class="brand-name">Arky</span>
          <span class="brand-sub">Foundation</span>
        </span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="#standard">Standard</a>
        <a href="#conformance">Conformance</a>
        <a href="#adopt">Adopt</a>
        <a class="nav-cta" href="../specs/core/ARKY-TIM-v1.md">Read the spec</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <div class="hero-top">
        <div class="hero-copy">
          <p class="kicker reveal hero-load">Neutral accountability layer&ensp;·&ensp;ARKY-TIM-v1</p>
          <h1 id="hero-title" class="reveal hero-load" style="--reveal-delay: 60ms"><span class="h1-mark">Arky</span></h1>
          <p class="tagline reveal hero-load" style="--reveal-delay: 120ms">A public standard for action and verification across agents, money, chains, and machines.</p>
          <p class="subline reveal hero-load" style="--reveal-delay: 180ms">Every action records who acted, on what evidence, under which policy, and what happened &mdash; as a signed, content-addressed receipt any system can replay.</p>
          <div class="hero-actions reveal hero-load" style="--reveal-delay: 240ms" aria-label="Primary actions">
            <a class="button primary" href="../specs/core/ARKY-TIM-v1.md">Read the spec</a>
            <a class="button" href="../CONFORMANCE.md">Run vectors</a>
            <a class="button" href="../packages/core/README.md">Implement</a>
          </div>
        </div>

        <div class="hero-net reveal hero-load" style="--reveal-delay: 340ms">
          <svg viewBox="0 0 400 400" role="img" aria-labelledby="net-title net-desc">
            <title id="net-title">Arky actor network</title>
            <desc id="net-desc">AI agents, space devices, banks, and blockchains exchange signed evidence and receipts through a neutral Arky hub at the center.</desc>

            <!-- engineering grid + orbit rings -->
            <g class="net-grid">
              <path d="M40 200H360M200 40V360"></path>
              <circle cx="200" cy="200" r="158"></circle>
            </g>
            <circle class="net-orbit spin" cx="200" cy="200" r="118"></circle>
            <circle class="net-orbit" cx="200" cy="200" r="158"></circle>

            <!-- static spokes (actor -> hub), then live animated overlays -->
            <g class="net-spoke">
              <path d="M200 200L96 96"></path>
              <path d="M200 200L304 96"></path>
              <path d="M200 200L304 304"></path>
              <path d="M200 200L96 304"></path>
            </g>
            <g aria-hidden="true">
              <path class="net-spoke-live inbound" d="M96 96L200 200" style="animation-delay:0s"></path>
              <path class="net-spoke-live outbound" d="M200 200L304 96" style="animation-delay:-0.9s"></path>
              <path class="net-spoke-live inbound" d="M304 304L200 200" style="animation-delay:-1.8s"></path>
              <path class="net-spoke-live outbound" d="M200 200L96 304" style="animation-delay:-2.7s"></path>
            </g>

            <!-- ACTOR: AI agent (top-left) — robot head -->
            <g class="net-node" data-actor="agent" transform="translate(96 96)" aria-label="AI agent">
              <rect class="net-chip" x="-30" y="-30" width="60" height="60" rx="9"></rect>
              <!-- Lucide "bot" -->
              <g class="net-glyph" transform="translate(-18 -18) scale(1.5)">
                <path d="M12 8V4H8"></path>
                <rect width="16" height="12" x="4" y="8" rx="2"></rect>
                <path d="M2 14h2"></path>
                <path d="M20 14h2"></path>
                <path d="M15 13v2"></path>
                <path d="M9 13v2"></path>
              </g>
              <text class="net-name" x="0" y="44" text-anchor="middle">Agents</text>
            </g>

            <!-- ACTOR: Space device (top-right) -->
            <g class="net-node" data-actor="space" transform="translate(304 96)" aria-label="Space device">
              <rect class="net-chip" x="-30" y="-30" width="60" height="60" rx="9"></rect>
              <!-- Lucide "satellite" -->
              <g class="net-glyph" transform="translate(-18 -18) scale(1.5)">
                <path d="m13.5 6.5-3.148-3.148a1.205 1.205 0 0 0-1.704 0L6.352 5.648a1.205 1.205 0 0 0 0 1.704L9.5 10.5"></path>
                <path d="M16.5 7.5 19 5"></path>
                <path d="m17.5 10.5 3.148 3.148a1.205 1.205 0 0 1 0 1.704l-2.296 2.296a1.205 1.205 0 0 1-1.704 0L13.5 14.5"></path>
                <path d="M9 21a6 6 0 0 0-6-6"></path>
                <path d="M9.352 10.648a1.205 1.205 0 0 0 0 1.704l2.296 2.296a1.205 1.205 0 0 0 1.704 0l4.296-4.296a1.205 1.205 0 0 0 0-1.704l-2.296-2.296a1.205 1.205 0 0 0-1.704 0z"></path>
              </g>
              <text class="net-name" x="0" y="44" text-anchor="middle">Space</text>
            </g>

            <!-- ACTOR: Bank (bottom-right) -->
            <g class="net-node" data-actor="bank" transform="translate(304 304)" aria-label="Bank">
              <rect class="net-chip" x="-30" y="-30" width="60" height="60" rx="9"></rect>
              <!-- Lucide "landmark" -->
              <g class="net-glyph" transform="translate(-18 -18) scale(1.5)">
                <path d="M10 18v-7"></path>
                <path d="M11.119 2.205a2 2 0 0 1 1.762 0l7.84 3.846A.5.5 0 0 1 20.5 7h-17a.5.5 0 0 1-.22-.949z"></path>
                <path d="M14 18v-7"></path>
                <path d="M18 18v-7"></path>
                <path d="M3 22h18"></path>
                <path d="M6 18v-7"></path>
              </g>
              <text class="net-name" x="0" y="44" text-anchor="middle">Banks</text>
            </g>

            <!-- ACTOR: Blockchain (bottom-left) -->
            <g class="net-node" data-actor="chain" transform="translate(96 304)" aria-label="Blockchain">
              <rect class="net-chip" x="-30" y="-30" width="60" height="60" rx="9"></rect>
              <!-- Lucide "link" -->
              <g class="net-glyph" transform="translate(-18 -18) scale(1.5)">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
              </g>
              <text class="net-name" x="0" y="44" text-anchor="middle">Chains</text>
            </g>

            <!-- CENTRAL ARKY HUB -->
            <g aria-hidden="true">
              <circle class="net-hub-pulse" cx="200" cy="200" r="32"></circle>
              <circle class="net-hub-ring" cx="200" cy="200" r="32"></circle>
              <path class="net-hub-mark" d="M184 200h7l4-10 6 20 4-10h7"></path>
              <text class="net-hub-label" x="200" y="252">ARKY</text>
            </g>

            <!-- travelling packets, positioned by script -->
            <circle class="net-packet evidence" id="net-packet-a" cx="96" cy="96" r="3.4"></circle>
            <circle class="net-packet" id="net-packet-b" cx="200" cy="200" r="3.4"></circle>
          </svg>
          <span class="net-readout" aria-hidden="true">evidence in <b>&middot;</b> signed receipt out</span>
        </div>
      </div>

      <div class="hero-stage reveal hero-load" style="--reveal-delay: 380ms" aria-label="Arky protocol schematic">
        <svg class="stage-svg" viewBox="0 0 1440 440" preserveAspectRatio="xMidYMid meet" role="img" aria-labelledby="schematic-title schematic-desc">
          <title id="schematic-title">Arky protocol flow</title>
          <desc id="schematic-desc">Evidence moves through witness, decision, execution, and receipt stages, ending in a signed receipt.</desc>
          <defs>
            <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M0 0L10 5L0 10Z" fill="var(--lines)"></path>
            </marker>
          </defs>

          <!-- Faint circuit substrate spanning the stage -->
          <g class="schematic-faint">
            <path d="M40 70h180l30-30h160l30 30h300M900 70h120l40-40h160l40 40h120"></path>
            <path d="M40 372h220l34 34h220M740 406h160l40-34h260l40 34h160"></path>
            <path d="M120 96v-46M520 100v-50M1000 96v-46M1320 100v-50"></path>
            <path d="M40 200h60M40 240h44M1340 200h60M1356 240h44"></path>
          </g>
          <g class="schematic-oxide">
            <path d="M40 300h260l40-40h220l40 40h300"></path>
            <path d="M1040 300h120l40-40h200"></path>
          </g>

          <!-- Main signal route across the full width -->
          <path class="schematic-line" d="M150 220C300 100 430 100 580 220S830 340 980 220S1230 100 1300 220" marker-end="url(#arrow)"></path>
          <path class="live-route" id="live-route" d="M150 220C300 100 430 100 580 220S830 340 980 220S1230 100 1300 220"></path>

          <!-- Dimension ticks at route endpoints -->
          <g class="schematic-faint">
            <path d="M150 244v-12M150 220h-12M1300 244v-12M1300 220h12"></path>
          </g>

          <!-- Via dots along the substrate -->
          <g class="bp-via" opacity="0.5">
