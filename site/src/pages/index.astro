    <!-- Dimension lines with end ticks -->
    <g class="bp-faint" fill="none">
      <path d="M100 650h240"></path>
      <path d="M100 644v12M340 644v12"></path>
      <path d="M40 150v-44M40 138h16M40 150h16"></path>
      <path d="M1560 760v-44M1560 748h-16M1560 760h-16"></path>
      <path d="M1520 380v-88M1514 380h12M1526 380h12M1514 292h12M1526 292h12"></path>
    </g>
