          <div class="metric">
            <span class="num">2</span>
            <span class="cap">independent implementations<br>TypeScript &middot; Rust, cross-checked byte-for-byte</span>
          </div>
          <div class="metric">
            <span class="num">L2</span>
            <span class="cap">core-loop coverage<br>production-ready manifests</span>
          </div>
        </div>

