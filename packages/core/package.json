{
  "name": "@arky/core",
  "version": "0.1.0",
  "description": "Reference TypeScript implementation of Arky TIM: produce and verify Time-Identity-Measurement receipts (canonicalization, content addressing, detached JWS, witnessing).",
  "keywords": [
    "arky",
    "ed25519",
    "jcs",
    "jws",
    "receipts",
    "rfc8785",
    "tim"
  ],
  "homepage": "https://arky.foundation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/arky-foundation/arky.foundation.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-dts": "^5.0.2"
  }
}
