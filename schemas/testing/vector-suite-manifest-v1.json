{
  "$id": "https://arky.foundation/schemas/testing/vector-suite-manifest-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arky Vector Suite Manifest (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["suite", "version", "level_coverage", "files", "ts"],
  "properties": {
    "suite": {"type": "string"},
    "version": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Semver"},
    "level_coverage": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "ts": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Rfc3339"},
    "cid": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Cid"},
    "sig": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/JwsCompact"}
  }
}
