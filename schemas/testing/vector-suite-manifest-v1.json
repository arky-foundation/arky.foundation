{
  "$id": "https://arky.foundation/schemas/testing/vector-suite-manifest-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arky Vector Suite Manifest (v1)",
  "description": "A vector suite manifest describes the test vectors for one spec. Two shapes are accepted: the level-indexed suite shape (used by most suites) and the flat list shape (used by cross-spec integration suites).",
  "oneOf": [
    {"$ref": "#/$defs/LevelIndexedSuite"},
    {"$ref": "#/$defs/FlatListSuite"}
  ],
  "$defs": {
    "LevelIndexedSuite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suite", "spec", "version", "levels", "total_vectors"],
      "properties": {
        "suite": {"type": "string"},
        "spec": {"type": "string"},
        "version": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Semver"},
        "description": {"type": "string"},
        "levels": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "vectors", "coverage"],
            "properties": {
              "name": {"type": "string"},
              "description": {"type": "string"},
              "vectors": {"type": "array", "items": {"type": "string"}},
              "coverage": {"type": "integer", "minimum": 0},
              "focus_areas": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "total_vectors": {"type": "integer", "minimum": 0},
        "supported_formats": {"type": "array", "items": {"type": "string"}},
        "status": {
          "type": "object",
          "properties": {
            "overall_coverage": {"type": "string"},
            "ready_for_production": {"type": "boolean"},
            "last_updated": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Rfc3339"}
          }
        },
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "fixtures": {"type": "object", "additionalProperties": {"type": "string"}},
        "references": {"type": "object", "additionalProperties": {"type": "string"}},
        "cid": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Cid"},
        "sig": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/JwsCompact"}
      }
    },
    "FlatListSuite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_id", "name", "vectors", "ts"],
      "properties": {
        "manifest_id": {"type": "string"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "spec_refs": {"type": "array", "items": {"type": "string"}},
        "vectors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "file"],
            "properties": {
              "id": {"type": "string"},
              "file": {"type": "string"},
              "description": {"type": "string"},
              "tags": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "conformance_levels": {"type": "object", "additionalProperties": {"type": "string"}},
        "ts": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Rfc3339"},
        "cid": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/Cid"},
        "sig": {"$ref": "https://arky.foundation/schemas/common-defs-v1.json#/$defs/JwsCompact"}
      }
    }
  }
}
