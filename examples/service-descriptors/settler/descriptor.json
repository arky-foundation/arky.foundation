{
  "service_id": "arky:example/settler",
  "service_type": "settler",
  "version": "1.0.0",
  "spec_ids": [
    "ARKY-SETTLERS-v1",
    "ARKY-WIRE-v1",
    "ARKY-DISCOVERY-v1"
  ],
  "endpoints": [
    {
      "name": "execute",
      "path": "/settler/execute",
      "method": "POST",
      "media_types": ["application/arky.kernel+json"]
    },
    {
      "name": "status",
      "path": "/settler/status/{commitment_id}",
      "method": "GET",
      "media_types": ["application/arky.xr+json"]
    },
    {
      "name": "xr",
      "path": "/settler/xr/{cid}",
      "method": "GET",
      "media_types": ["application/arky.xr+json"]
    }
  ],
  "capabilities": {
    "rails_supported": ["caip2:eip155:*", "sepa:eu", "ach:us", "controller:*"],
    "verbs_supported": ["arky:verb/pay@v1", "arky:verb/refund@v1", "arky:verb/revoke@v1"],
    "rollback_support": {"sepa:eu": {"window": "P2D"}, "ach:us": {"window": "P2D"}},
    "xr_anchor": "optional",
    "idempotency": "keyed",
    "attestation": {"required": false, "types": ["arky:attest/rats.eat@v1"]}
  },
  "policy_defaults": {"policy_pack_id": "arky:policy/global@v1"},
  "security": {
    "transport": ["https"],
    "auth": ["none"],
    "rate_limits": {"per_minute": 600, "burst": 300}
  },
  "ts": "2025-10-15T00:00:00Z",
